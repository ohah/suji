{
  "$schema": "../../suji.schema.json",
  "app": {
    "name": "Multi Backend Example",
    "version": "0.1.0"
  },
  "windows": [
    {
      "name": "main",
      "title": "Suji Multi-Backend Demo",
      "width": 1024,
      "height": 768,
      "debug": true,
      "protocol": "suji"
    }
  ],
  "plugins": ["state", "window-state", "positioner"],
  "backends": [
    { "name": "zig", "lang": "zig", "entry": "backends/zig" },
    { "name": "rust", "lang": "rust", "entry": "backends/rust" },
    { "name": "go", "lang": "go", "entry": "backends/go" },
    { "name": "node", "lang": "node", "entry": "backends/node" },
    { "name": "lua", "lang": "lua", "entry": "backends/lua" },
    { "name": "python", "lang": "python", "entry": "backends/python" }
  ],
  "frontend": {
    "dir": "frontend",
    "dev_url": "http://localhost:12300",
    "dev_command": "bun run dev",
    "build_command": "bun run build",
    "dist_dir": "frontend/dist"
  },
  "fs": {
    "allowedRoots": ["*"]
  }
}
