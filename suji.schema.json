{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ohah/suji/blob/main/suji.schema.json",
  "title": "suji.json",
  "description": "Suji 데스크톱 앱 프레임워크 프로젝트 설정",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema 경로"
    },
    "app": {
      "type": "object",
      "description": "앱 메타데이터",
      "properties": {
        "name": {
          "type": "string",
          "default": "Suji App",
          "description": "앱 이름"
        },
        "version": {
          "type": "string",
          "default": "0.1.0",
          "description": "앱 버전 (semver)"
        },
        "entitlements": {
          "type": "string",
          "description": "사용자 entitlements plist 경로 — 모든 binary에 단독 적용 (Suji default helper별 entitlements 대체)."
        },
        "stripCef": {
          "type": "boolean",
          "default": true,
          "description": "CEF framework binary debug symbol strip (~30MB 절약)."
        },
        "minimumSystemVersion": {
          "type": "string",
          "default": "12.0",
          "description": "macOS 최소 배포 타겟. Info.plist LSMinimumSystemVersion + 메인 바이너리 minos(vtool) + Go 백엔드 MACOSX_DEPLOYMENT_TARGET 에 일관 적용. 번들 CEF 가 12.0 프리빌트라 그 아래는 12.0 으로 보정. macOS 빌드에서만 의미."
        },
        "icon": {
          "type": "string",
          "description": "앱 아이콘 경로(프로젝트 기준). macOS: .png(1024 권장)면 빌드 시 .icns 생성, .icns 면 복사 → Contents/Resources/AppIcon.icns + Info.plist CFBundleIconFile. 비어있으면 기본 아이콘."
        },
        "locales": {
          "type": "array",
          "items": { "type": "string" },
          "description": "번들에 포함할 CEF locale (`en`, `ko` 등). 미설정 시 default `[\"en\"]`. `[\"*\"]`면 220개 전부."
        },
        "quitOnAllWindowsClosed": {
          "type": "boolean",
          "default": false,
          "description": "마지막 창 close 시 코어가 자동 cef.quit(). false면 사용자 코드가 'window:all-closed' 구독 후 직접 quit (Electron canonical 패턴)."
        },
        "deepLinkSchemes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "딥링크 URL scheme. macOS .app 번들 Info.plist CFBundleURLTypes 자동 주입 → `myapp://...` 가 OS 레벨에서 이 앱으로 라우팅. 유효 scheme(ALPHA 시작, [A-Za-z0-9+.-])만, 무효는 skip."
        },
        "crashReporter": {
          "type": "object",
          "description": "CEF Crashpad/Breakpad startup config. CEF initialize 전에 crash_reporter.cfg를 생성한다.",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "productName": { "type": "string", "description": "Crash reporter ProductName. 기본값은 app.name." },
            "submitURL": { "type": "string", "description": "크래시 업로드 endpoint. uploadToServer=true면 runtime start에서도 필요." },
            "uploadToServer": { "type": "boolean", "default": true },
            "ignoreSystemCrashHandler": { "type": "boolean", "default": false },
            "rateLimit": { "type": "boolean", "default": true },
            "maxUploadsPerDay": { "type": "integer", "minimum": 0, "default": 5 },
            "maxDatabaseSizeInMb": { "type": "integer", "minimum": 0, "default": 20 },
            "maxDatabaseAgeInDays": { "type": "integer", "minimum": 0, "default": 5 },
            "extra": {
              "type": "object",
              "additionalProperties": { "type": "string" },
              "description": "프로세스별 crash key 선언/초기값. key는 ASCII [A-Za-z0-9_-] 39바이트 이하."
            },
            "globalExtra": {
              "type": "object",
              "additionalProperties": { "type": "string" },
              "description": "모든 프로세스 crash key 선언/초기값. key는 ASCII [A-Za-z0-9_-] 39바이트 이하."
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "windows": {
      "type": "array",
      "description": "윈도우 설정 목록. 첫 번째 항목이 메인 윈도우 (CEF 초기화 시 사이즈/타이틀 사용).",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "WM 등록 이름 (singleton 키). 첫 창의 기본값은 'main'. 동일 이름은 기존 창 id 반환."
          },
          "title": {
            "type": "string",
            "default": "Suji App",
            "description": "윈도우 타이틀"
          },
          "width": {
            "type": "integer",
            "default": 1024,
            "minimum": 0,
            "description": "윈도우 너비 (px). 음수는 0으로 clamp."
          },
          "height": {
            "type": "integer",
            "default": 768,
            "minimum": 0,
            "description": "윈도우 높이 (px). 음수는 0으로 clamp."
          },
          "x": {
            "type": "integer",
            "default": 0,
            "description": "초기 x 좌표 (px). 0이면 OS cascade 자동 배치."
          },
          "y": {
            "type": "integer",
            "default": 0,
            "description": "초기 y 좌표 (px). 0이면 OS cascade 자동 배치."
          },
          "frame": {
            "type": "boolean",
            "default": true,
            "description": "OS 윈도우 프레임 표시. false면 frameless (타이틀바/리사이즈 핸들 제거)."
          },
          "transparent": {
            "type": "boolean",
            "default": false,
            "description": "투명 NSWindow + clear background. HTML body도 transparent여야 의미 있음. macOS만."
          },
          "backgroundColor": {
            "type": "string",
            "pattern": "^#([0-9A-Fa-f]{6}|[0-9A-Fa-f]{8})$",
            "description": "배경색 (#RRGGBB 또는 #RRGGBBAA). transparent와 함께면 transparent 우선. macOS만."
          },
          "titleBarStyle": {
            "type": "string",
            "enum": ["default", "hidden", "hiddenInset"],
            "default": "default",
            "description": "타이틀바 스타일 (macOS). hidden/hiddenInset은 traffic light 유지 + content view 확장."
          },
          "resizable": {
            "type": "boolean",
            "default": true,
            "description": "사용자 리사이즈 허용. frame=false일 때는 무시."
          },
          "alwaysOnTop": {
            "type": "boolean",
            "default": false,
            "description": "NSFloatingWindowLevel — 일반 창 위 항상 표시. macOS만."
          },
          "minWidth": {
            "type": "integer",
            "default": 0,
            "minimum": 0,
            "description": "최소 콘텐츠 너비 (0 = 제한 없음)"
          },
          "minHeight": {
            "type": "integer",
            "default": 0,
            "minimum": 0,
            "description": "최소 콘텐츠 높이 (0 = 제한 없음)"
          },
          "maxWidth": {
            "type": "integer",
            "default": 0,
            "minimum": 0,
            "description": "최대 콘텐츠 너비 (0 = 제한 없음)"
          },
          "maxHeight": {
            "type": "integer",
            "default": 0,
            "minimum": 0,
            "description": "최대 콘텐츠 높이 (0 = 제한 없음)"
          },
          "fullscreen": {
            "type": "boolean",
            "default": false,
            "description": "시작 시 전체화면 전환. macOS만."
          },
          "parent": {
            "type": "string",
            "description": "부모 창 이름. addChildWindow로 attach (시각 관계만 — 부모 close해도 자식은 유지). macOS만."
          },
          "url": {
            "type": "string",
            "description": "초기 로드 URL. 생략 시 frontend dev_url/dist 자동 선택 (첫 창에만 적용)."
          },
          "visible": {
            "type": "boolean",
            "default": true,
            "description": "초기 표시 여부. false면 hidden 상태로 생성."
          },
          "debug": {
            "type": "boolean",
            "default": false,
            "description": "시작 시 DevTools 자동 오픈 (개발용)"
          },
          "protocol": {
            "type": "string",
            "enum": ["file", "suji"],
            "default": "file",
            "description": "프론트엔드 로딩 프로토콜. 'suji'는 suji:// 커스텀 프로토콜 (CORS/fetch/Cookie/SW 정상 동작)."
          }
        },
        "additionalProperties": false
      }
    },
    "backend": {
      "type": "object",
      "description": "단일 백엔드 설정 (backends와 동시 사용 불가)",
      "properties": {
        "lang": {
          "type": "string",
          "enum": ["zig", "rust", "go", "node", "lua", "python"],
          "default": "zig",
          "description": "백엔드 언어"
        },
        "entry": {
          "type": "string",
          "description": "백엔드 엔트리 디렉토리 경로"
        }
      },
      "required": ["lang", "entry"],
      "additionalProperties": false
    },
    "backends": {
      "type": "array",
      "description": "멀티 백엔드 설정 (backend와 동시 사용 불가)",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "백엔드 식별자 (target 지정 시 사용)"
          },
          "lang": {
            "type": "string",
            "enum": ["zig", "rust", "go", "node", "lua", "python"],
            "description": "백엔드 언어"
          },
          "entry": {
            "type": "string",
            "description": "백엔드 엔트리 디렉토리 경로"
          }
        },
        "required": ["name", "lang", "entry"],
        "additionalProperties": false
      }
    },
    "plugins": {
      "type": "array",
      "description": "활성화할 플러그인 목록. 문자열은 공식/로컬 플러그인 이름, 객체는 외부 source와 outbound permissions를 지정.",
      "items": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "플러그인 식별자. 라우팅/패키징 디렉토리 이름으로 사용."
              },
              "source": {
                "type": "string",
                "description": "외부 플러그인 source. 로컬 경로(./plugins/x, ~/x, /abs/x) 또는 GitHub URL(github.com/owner/repo, https://github.com/owner/repo)."
              },
              "permissions": {
                "type": "array",
                "description": "플러그인이 다른 채널로 invoke할 때 허용할 outbound cmd 목록. 생략하면 기존 호환을 위해 unrestricted, []는 deny-all. '*' 또는 'prefix:*' 허용.",
                "items": { "type": "string" }
              }
            },
            "required": ["name"],
            "additionalProperties": false
          }
        ]
      },
      "examples": [["state", { "name": "analytics", "source": "github.com/someone/suji-plugin-analytics", "permissions": ["state:get", "state:set"] }]]
    },
    "asset_dir": {
      "type": "string",
      "default": "assets",
      "description": "정적 에셋 디렉토리"
    },
    "frontend": {
      "type": "object",
      "description": "프론트엔드 설정",
      "properties": {
        "dir": {
          "type": "string",
          "default": "frontend",
          "description": "프론트엔드 소스 디렉토리"
        },
        "dev_url": {
          "type": "string",
          "default": "http://localhost:12300",
          "description": "개발 서버 URL (suji dev 시 사용)"
        },
        "dev_command": {
          "type": "string",
          "default": "bun run dev",
          "description": "suji dev가 frontend.dir에서 실행할 개발 서버 명령."
        },
        "build_command": {
          "type": "string",
          "default": "bun run build",
          "description": "suji build가 frontend.dir에서 실행할 빌드 명령."
        },
        "dist_dir": {
          "type": "string",
          "default": "frontend/dist",
          "description": "프로덕션 빌드 출력 디렉토리"
        }
      },
      "additionalProperties": false
    }
  },
  "oneOf": [
    {
      "properties": { "backend": {}, "backends": false },
      "description": "단일 백엔드 모드"
    },
    {
      "properties": { "backends": {}, "backend": false },
      "description": "멀티 백엔드 모드"
    },
    {
      "not": {
        "anyOf": [
          { "required": ["backend"] },
          { "required": ["backends"] }
        ]
      },
      "description": "백엔드 없음 (프론트엔드 전용)"
    }
  ],
  "additionalProperties": false
}
