{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ohah/suji/blob/main/suji.schema.json",
  "title": "suji.json",
  "description": "Suji 데스크톱 앱 프레임워크 프로젝트 설정",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema 경로"
    },
    "app": {
      "type": "object",
      "description": "앱 메타데이터",
      "properties": {
        "name": {
          "type": "string",
          "default": "Suji App",
          "description": "앱 이름"
        },
        "version": {
          "type": "string",
          "default": "0.1.0",
          "description": "앱 버전 (semver)"
        }
      },
      "additionalProperties": false
    },
    "windows": {
      "type": "array",
      "description": "윈도우 설정 목록. 첫 번째 항목 또는 name='main'이 메인 윈도우.",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "윈도우 고유 식별자. 'main'이면 메인 윈도우."
          },
          "create": {
            "type": "boolean",
            "default": true,
            "description": "앱 시작 시 자동 생성 여부. false면 설정만 등록 (런타임에 이름으로 생성)."
          },
          "title": {
            "type": "string",
            "default": "Suji App",
            "description": "윈도우 타이틀"
          },
          "width": {
            "type": "integer",
            "default": 800,
            "minimum": 100,
            "description": "윈도우 너비 (px)"
          },
          "height": {
            "type": "integer",
            "default": 600,
            "minimum": 100,
            "description": "윈도우 높이 (px)"
          },
          "x": {
            "type": ["integer", "null"],
            "default": null,
            "description": "윈도우 x 좌표 (null이면 OS 기본)"
          },
          "y": {
            "type": ["integer", "null"],
            "default": null,
            "description": "윈도우 y 좌표 (null이면 OS 기본)"
          },
          "center": {
            "type": "boolean",
            "default": true,
            "description": "화면 중앙 배치"
          },
          "minWidth": {
            "type": "integer",
            "default": 0,
            "description": "최소 너비"
          },
          "minHeight": {
            "type": "integer",
            "default": 0,
            "description": "최소 높이"
          },
          "maxWidth": {
            "type": "integer",
            "default": 0,
            "description": "최대 너비 (0 = 제한 없음)"
          },
          "maxHeight": {
            "type": "integer",
            "default": 0,
            "description": "최대 높이 (0 = 제한 없음)"
          },
          "resizable": {
            "type": "boolean",
            "default": true,
            "description": "크기 조절 가능"
          },
          "movable": {
            "type": "boolean",
            "default": true,
            "description": "이동 가능"
          },
          "minimizable": {
            "type": "boolean",
            "default": true,
            "description": "최소화 가능"
          },
          "maximizable": {
            "type": "boolean",
            "default": true,
            "description": "최대화 가능"
          },
          "closable": {
            "type": "boolean",
            "default": true,
            "description": "닫기 가능"
          },
          "focusable": {
            "type": "boolean",
            "default": true,
            "description": "포커스 가능"
          },
          "alwaysOnTop": {
            "type": "boolean",
            "default": false,
            "description": "항상 위에 표시"
          },
          "fullscreen": {
            "type": "boolean",
            "default": false,
            "description": "전체화면"
          },
          "fullscreenable": {
            "type": "boolean",
            "default": true,
            "description": "전체화면 전환 가능"
          },
          "skipTaskbar": {
            "type": "boolean",
            "default": false,
            "description": "작업표시줄에서 숨김"
          },
          "kiosk": {
            "type": "boolean",
            "default": false,
            "description": "키오스크 모드"
          },
          "show": {
            "type": "boolean",
            "default": true,
            "description": "생성 시 즉시 표시 (false면 show() 호출 필요)"
          },
          "icon": {
            "type": ["string", "null"],
            "default": null,
            "description": "윈도우 아이콘 경로"
          },
          "frame": {
            "type": "boolean",
            "default": true,
            "description": "OS 윈도우 프레임 표시 (false = 프레임리스)"
          },
          "transparent": {
            "type": "boolean",
            "default": false,
            "description": "투명 배경"
          },
          "opacity": {
            "type": "number",
            "default": 1.0,
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "윈도우 불투명도"
          },
          "backgroundColor": {
            "type": "string",
            "default": "#FFFFFF",
            "description": "배경색 (hex)"
          },
          "hasShadow": {
            "type": "boolean",
            "default": true,
            "description": "윈도우 그림자"
          },
          "titleBarStyle": {
            "type": "string",
            "enum": ["default", "hidden", "hiddenInset", "customButtonsOnHover"],
            "default": "default",
            "description": "타이틀바 스타일 (macOS)"
          },
          "titleBarOverlay": {
            "type": ["object", "boolean", "null"],
            "default": null,
            "description": "Windows 컨트롤 오버레이 설정"
          },
          "trafficLightPosition": {
            "type": ["object", "null"],
            "default": null,
            "description": "macOS 신호등 버튼 위치 { x, y }"
          },
          "vibrancy": {
            "type": ["string", "null"],
            "default": null,
            "description": "macOS vibrancy 효과"
          },
          "backgroundMaterial": {
            "type": "string",
            "enum": ["none", "acrylic", "mica", "tabbed"],
            "default": "none",
            "description": "Windows 11 배경 재질"
          },
          "parent": {
            "type": ["string", "null"],
            "default": null,
            "description": "부모 윈도우 name"
          },
          "modal": {
            "type": "boolean",
            "default": false,
            "description": "모달 윈도우 (parent 필수)"
          },
          "devTools": {
            "type": "boolean",
            "default": true,
            "description": "DevTools 허용 여부"
          },
          "contextIsolation": {
            "type": "boolean",
            "default": false,
            "description": "JS 컨텍스트 격리. true면 웹페이지가 suji bridge를 변조할 수 없음."
          },
          "incognito": {
            "type": "boolean",
            "default": false,
            "description": "시크릿 모드. 세션/쿠키/캐시를 메모리에만 저장."
          },
          "backgroundThrottling": {
            "type": "boolean",
            "default": true,
            "description": "백그라운드 시 타이머/애니메이션 쓰로틀링"
          },
          "autoHideMenuBar": {
            "type": "boolean",
            "default": false,
            "description": "메뉴바 자동 숨김 (Alt 키로 토글)"
          },
          "userAgent": {
            "type": ["string", "null"],
            "default": null,
            "description": "커스텀 User-Agent 문자열"
          },
          "darkTheme": {
            "type": "boolean",
            "default": false,
            "description": "다크 테마 강제"
          },
          "acceptFirstMouse": {
            "type": "boolean",
            "default": false,
            "description": "비활성 윈도우의 첫 클릭 허용 (macOS)"
          },
          "type": {
            "type": "string",
            "enum": ["normal", "desktop", "dock", "toolbar", "splash", "notification"],
            "default": "normal",
            "description": "윈도우 타입"
          },
          "roundedCorners": {
            "type": "boolean",
            "default": true,
            "description": "둥근 모서리 (macOS)"
          },
          "thickFrame": {
            "type": "boolean",
            "default": true,
            "description": "두꺼운 프레임 스타일 (Windows)"
          },
          "tabbingIdentifier": {
            "type": ["string", "null"],
            "default": null,
            "description": "네이티브 탭 그룹 식별자 (macOS)"
          },
          "hiddenInMissionControl": {
            "type": "boolean",
            "default": false,
            "description": "Mission Control에서 숨김 (macOS)"
          },
          "accessibleTitle": {
            "type": ["string", "null"],
            "default": null,
            "description": "스크린 리더용 대체 타이틀"
          },
          "proxyUrl": {
            "type": ["string", "null"],
            "default": null,
            "description": "윈도우별 프록시 URL"
          },
          "dataDirectory": {
            "type": ["string", "null"],
            "default": null,
            "description": "웹뷰 데이터 디렉토리 (세션 분리용)"
          },
          "url": {
            "type": ["string", "null"],
            "default": null,
            "description": "로드할 URL"
          },
          "file": {
            "type": ["string", "null"],
            "default": null,
            "description": "로드할 로컬 파일 경로"
          },
          "debug": {
            "type": "boolean",
            "default": false,
            "description": "DevTools 자동 오픈 (개발 시)"
          },
          "protocol": {
            "type": "string",
            "enum": ["file", "suji"],
            "default": "file",
            "description": "이 윈도우의 프론트엔드 로딩 프로토콜 (메인 윈도우만 의미 있음)"
          },
          "visible": {
            "type": "boolean",
            "default": true,
            "description": "초기 표시 여부"
          }
        },
        "additionalProperties": false
      }
    },
    "backend": {
      "type": "object",
      "description": "단일 백엔드 설정 (backends와 동시 사용 불가)",
      "properties": {
        "lang": {
          "type": "string",
          "enum": ["zig", "rust", "go", "node"],
          "default": "zig",
          "description": "백엔드 언어"
        },
        "entry": {
          "type": "string",
          "description": "백엔드 엔트리 디렉토리 경로"
        }
      },
      "required": ["lang", "entry"],
      "additionalProperties": false
    },
    "backends": {
      "type": "array",
      "description": "멀티 백엔드 설정 (backend와 동시 사용 불가)",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "백엔드 식별자 (target 지정 시 사용)"
          },
          "lang": {
            "type": "string",
            "enum": ["zig", "rust", "go", "node"],
            "description": "백엔드 언어"
          },
          "entry": {
            "type": "string",
            "description": "백엔드 엔트리 디렉토리 경로"
          }
        },
        "required": ["name", "lang", "entry"],
        "additionalProperties": false
      }
    },
    "plugins": {
      "type": "array",
      "description": "활성화할 플러그인 목록",
      "items": {
        "type": "string"
      },
      "examples": [["state"]]
    },
    "asset_dir": {
      "type": "string",
      "default": "assets",
      "description": "정적 에셋 디렉토리"
    },
    "frontend": {
      "type": "object",
      "description": "프론트엔드 설정",
      "properties": {
        "dir": {
          "type": "string",
          "default": "frontend",
          "description": "프론트엔드 소스 디렉토리"
        },
        "dev_url": {
          "type": "string",
          "default": "http://localhost:5173",
          "description": "개발 서버 URL (suji dev 시 사용)"
        },
        "dist_dir": {
          "type": "string",
          "default": "frontend/dist",
          "description": "프로덕션 빌드 출력 디렉토리"
        },
        "protocol": {
          "type": "string",
          "enum": ["file", "suji"],
          "default": "file",
          "description": "프론트엔드 로딩 프로토콜. 'suji': suji:// 커스텀 프로토콜 (CORS/fetch/Cookie/SW 정상 동작). 전역 설정 — 모든 윈도우에 동일 적용."
        }
      },
      "additionalProperties": false
    }
  },
  "oneOf": [
    {
      "properties": { "backend": {}, "backends": false },
      "description": "단일 백엔드 모드"
    },
    {
      "properties": { "backends": {}, "backend": false },
      "description": "멀티 백엔드 모드"
    },
    {
      "not": {
        "anyOf": [
          { "required": ["backend"] },
          { "required": ["backends"] }
        ]
      },
      "description": "백엔드 없음 (프론트엔드 전용)"
    }
  ],
  "additionalProperties": false
}
