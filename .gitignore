# Zig
.zig-cache/
zig-out/
zig-pkg/

# 루트 임시 검증 바이너리 (코드리뷰/simplify 에이전트가 만드는 standalone 컴파일 산출물 —
# 프로젝트 테스트는 tests/ 에 있음; 루트 test_* 는 항상 스트레이). git add -A 혼입 방지.
/test_*

# Rust
**/target/

# Go
poc/go-backend/*.dylib
poc/go-backend/*.h
examples/*/backends/go/*.dylib
examples/*/backends/go/*.h

# Node
node_modules/
bun.lock

# Astro docs site (website/) build artifacts
website/dist/
website/.astro/
# llms.txt/llms-full.txt 는 prebuild(gen-llms) 가 생성 — 배포 시 자동(artifact)
website/public/llms.txt
website/public/llms-full.txt
# but track website/bun.lock — CI(docs.yml)가 --frozen-lockfile 사용
!website/bun.lock

# Cargo lock in examples
examples/*/Cargo.lock
examples/*/backends/*/Cargo.lock

# Mobile host 생성 아티팩트 (build-lib.sh / xcodegen / gradle 산출물)
examples/ios/*/Vendor/
examples/*/*.xcodeproj/
examples/ios/*/*.xcodeproj/
examples/android/*/cpp/libs/
examples/android/*/jniLibs/
examples/android/*/.gradle/
examples/android/*/build/
examples/android/*/app/build/
examples/android/*/app/.cxx/
examples/android/*/local.properties
examples/ios/backends/rust/target/
examples/ios/backends/go/libsuji_go_backend.a
examples/ios/backends/go/libsuji_go_backend.h
examples/ios/backends/*/out/
tests/mobile-backends/.build/

# OS
.DS_Store

# Claude
.claude/
reference/
test-results/
*.app/

# npm pack artifacts
*.tgz

# suji build packaging output (examples) — macOS .app 는 위 `*.app/` 가 커버.
# Windows/Linux 는 `<AppName>-<ver>-<plat>-x64/` 디렉토리 + 동명 .zip 으로 떨어진다.
# run-python-packaged.sh 등 packaged e2e 가드가 생성하므로 트리 오염 방지.
examples/*/*-windows-x64/
examples/*/*-windows-x64.zip
examples/*/*-linux-x64/
examples/*/*-linux-x64.zip
# Windows Go 백엔드 (macOS/Linux .dylib/.h 는 위에서 이미 무시)
examples/*/backends/go/*.dll
# 예제 프런트엔드 빌드 출력 (suji build / packaged e2e 가 생성)
examples/*/frontend/dist/
# e2e CI 로그 아티팩트 디렉토리 (e2e.yml Windows arm 이 여기에 기록)
e2e-logs/

# website docs 의 reference/ 페이지는 위 광범위 `reference/` 무시에서 제외
# (그 패턴은 Claude 스크래치 dir 용 — docs 사이트 콘텐츠와 무관).
!website/src/content/docs/reference/
!website/src/content/docs/reference/roadmap.mdx
examples/android/*/assets/
